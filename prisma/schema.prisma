// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

/// User role in the system
/// TENANT: Can apply for properties
/// LANDLORD: Can list properties, view applications
/// AGENT: Can manage assigned properties on behalf of landlords
/// ADMIN: System administrator, manages notification templates
enum Role {
  TENANT
  LANDLORD
  AGENT
  ADMIN
}

/// Property type
enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  ROOM
}

/// Property listing status
enum PropertyStatus {
  DRAFT
  AVAILABLE
  RENTED
  PENDING
}

/// Subscription tier level
/// Used on User model to track current plan and on SubscriptionPlanConfig for plan definitions
enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

/// Type of user plan applies to
enum PlanType {
  TENANT
  LANDLORD
}

/// Billing cycle for subscriptions
enum BillingCycle {
  MONTHLY
  ANNUAL
}

/// Status of a subscription
enum SubscriptionStatus {
  TRIAL        // 7-day free trial
  ACTIVE       // Paid and active
  PAST_DUE     // Payment failed/expired, grace period
  CANCELLED    // User cancelled, remains active until period end
  EXPIRED      // Subscription period ended without renewal
}

/// Application status in the rental process
enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_INFO
  PREAPPROVED
  APPROVED
  REJECTED
  WITHDRAWN
}

/// Type of application event for audit trail
enum ApplicationEventType {
  CREATED
  STEP_COMPLETED
  SUBMITTED
  STATUS_CHANGED
  INFO_REQUESTED
  INFO_PROVIDED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  WITHDRAWN
}

/// Type of document uploaded with application
enum DocumentType {
  ID_DOCUMENT
  EMPLOYMENT_LETTER
  PAY_STUB
  INCOME_PROOF
  BANK_STATEMENT
  CREDIT_REPORT
  OTHER
}

/// Risk level classification based on total score
/// A (80-100): Excellent - approve immediately
/// B (65-79): Good - approve with standard terms
/// C (50-64): Fair - approve with conditions
/// D (0-49): Poor - decline or require cosigner
enum RiskLevel {
  A
  B
  C
  D
}

/// Insurance tier for rental contracts
/// NONE: No insurance selected
/// BASIC: Covers accidental damage up to 5M COP
/// PREMIUM: Covers accidental + natural disaster + theft up to 20M COP
enum InsuranceTier {
  NONE
  BASIC
  PREMIUM
}

/// Status of a rental contract
/// DRAFT: Contract created, not yet sent for signatures
/// PENDING_LANDLORD_SIGNATURE: Waiting for landlord to sign
/// PENDING_TENANT_SIGNATURE: Landlord signed, waiting for tenant
/// SIGNED: Both parties have signed
/// ACTIVE: Contract is in effect (start date has passed)
/// CANCELLED: Contract cancelled before activation
/// EXPIRED: Contract term has ended
enum ContractStatus {
  DRAFT
  PENDING_LANDLORD_SIGNATURE
  PENDING_TENANT_SIGNATURE
  SIGNED
  ACTIVE
  CANCELLED
  EXPIRED
}

/// Status of an active lease
/// ACTIVE: Lease in effect, tenant occupying
/// ENDING_SOON: Within 30 days of end date
/// ENDED: Natural termination at end date
/// TERMINATED: Early termination
enum LeaseStatus {
  ACTIVE
  ENDING_SOON
  ENDED
  TERMINATED
}

/// Payment method used for rent payment
enum PaymentMethod {
  PSE
  BANK_TRANSFER
  CASH
  NEQUI
  DAVIPLATA
  CHECK
}

/// Status of a tenant payment request
enum TenantPaymentRequestStatus {
  PENDING_VALIDATION
  APPROVED
  REJECTED
  DISPUTED
  CANCELLED
}

/// Status of a payment dispute
enum PaymentDisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FAVOR_TENANT
  RESOLVED_FAVOR_LANDLORD
  CLOSED
}

/// Account type for bank accounts
enum AccountType {
  AHORROS
  CORRIENTE
}

/// Status of a property visit
/// PENDING: Tenant requested, awaiting landlord response
/// ACCEPTED: Landlord accepted the visit
/// REJECTED: Landlord rejected the visit
/// CANCELLED: Either party cancelled
/// COMPLETED: Visit happened
/// RESCHEDULED: Original visit was rescheduled (superseded by new visit)
enum VisitStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

/// Channel for notification delivery
enum NotificationChannel {
  EMAIL
  PUSH
}

/// Status of notification delivery
enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

/// Type of document attached to a lease
enum LeaseDocumentType {
  CONTRACT_SIGNED
  PAYMENT_RECEIPT
  DELIVERY_INVENTORY
  RETURN_INVENTORY
  ADDENDUM
  PHOTO
  OTHER
}

/// Type of coupon discount
/// PERCENTAGE: Discount % off subscription price (1-100)
/// FIXED_AMOUNT: Fixed COP discount off subscription price
/// FREE_MONTHS: N months free (first period free, track remaining)
/// FULL_ACCESS: Full free access while coupon is valid
enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_MONTHS
  FULL_ACCESS
}

/// Type of activity event in the unified activity log
enum ActivityType {
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  APPLICATION_INFO_REQUESTED
  APPLICATION_DOCUMENT_UPLOADED
  PAYMENT_RECORDED
  PAYMENT_REQUEST_SUBMITTED
  PAYMENT_REQUEST_APPROVED
  PAYMENT_REQUEST_REJECTED
  PAYMENT_DISPUTE_OPENED
  VISIT_REQUESTED
  VISIT_ACCEPTED
  VISIT_REJECTED
  VISIT_CANCELLED
  VISIT_COMPLETED
  VISIT_RESCHEDULED
  CONTRACT_CREATED
  CONTRACT_SIGNED
  CONTRACT_ACTIVATED
  LEASE_CREATED
  LEASE_ENDING_SOON
  LEASE_ENDED
}

// ============================================
// MODELS
// ============================================

/// User model - synced from Supabase Auth via database trigger
/// The id matches auth.users.id (UUID)
model User {
  id         String  @id @db.Uuid // Same UUID as auth.users.id
  email      String  @unique
  role       Role    @default(TENANT)
  firstName        String? @map("first_name")
  lastName         String? @map("last_name")
  phone            String?
  rut              String? @db.VarChar(20)
  address          String? @db.VarChar(255)
  birthDate        DateTime? @map("birth_date") @db.Date
  emergencyContactName  String? @map("emergency_contact_name")  @db.VarChar(100)
  emergencyContactPhone String? @map("emergency_contact_phone") @db.VarChar(30)
  avatarUrl        String? @map("avatar_url")

  // Onboarding extended data (role-specific fields stored as JSON)
  onboardingData   Json?   @map("onboarding_data")

  // Subscription
  subscriptionPlan   SubscriptionPlan @default(FREE) @map("subscription_plan")
  subscriptionEndsAt DateTime?        @map("subscription_ends_at") // null = no expiration (free) or lifetime

  // Notification preferences
  emailNotificationsEnabled Boolean @default(true) @map("email_notifications_enabled")
  pushNotificationsEnabled  Boolean @default(true) @map("push_notifications_enabled")
  fcmToken                  String? @map("fcm_token")  // Firebase Cloud Messaging device token
  notificationSettings      Json?   @map("notification_settings") // Granular notification preferences

  // Account status (soft-delete)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  properties        Property[]
  applications      Application[]      @relation("TenantApplications")
  events            ApplicationEvent[] @relation("UserEvents")
  landlordNotes     LandlordNote[]     @relation("LandlordNotes")
  landlordContracts Contract[]         @relation("LandlordContracts")
  tenantContracts   Contract[]         @relation("TenantContracts")
  landlordLeases    Lease[]            @relation("LandlordLeases")
  tenantLeases      Lease[]            @relation("TenantLeases")
  recordedPayments  Payment[]          @relation("RecordedPayments")

  // Tenant payment simulation relations
  landlordPaymentMethods LandlordPaymentMethod[] @relation("LandlordPaymentMethods")
  tenantPaymentRequests  TenantPaymentRequest[]  @relation("TenantPaymentRequests")
  paymentValidations     TenantPaymentRequest[]  @relation("PaymentValidations")
  disputeResolutions     PaymentDispute[]        @relation("DisputeResolutions")

  // Property visits relations
  tenantVisits           PropertyVisit[]         @relation("TenantVisits")

  // Notification relations
  notificationLogs       NotificationLog[]

  // Agent property access relations
  agentAccess            PropertyAccess[] @relation("AgentAccess")
  grantedAccess          PropertyAccess[] @relation("GrantedAccess")

  // Chat relations
  chatMessages           ChatMessage[] @relation("ChatMessages")

  // Wishlist relations
  wishlistItems          WishlistItem[]

  // Lease document relations
  uploadedLeaseDocuments LeaseDocument[] @relation("UploadedLeaseDocuments")

  // Tenant preferences relation
  tenantPreference       TenantPreference?

  // Coupon relations
  couponUsages           CouponUsage[]

  // Activity log relations
  userActivities         ActivityLog[] @relation("UserActivities")
  actorActivities        ActivityLog[] @relation("ActorActivities")

  // Team member relations
  teamMembers            TeamMember[] @relation("TeamOwner")

  @@map("users")
}

/// Team member for landlord account collaboration
/// Allows landlords to invite other users to manage their properties
model TeamMember {
  id         String   @id @default(uuid()) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  name       String?  @db.VarChar(100)
  email      String   @db.VarChar(255)
  role       String   @default("viewer") @db.VarChar(20) // admin, manager, accountant, viewer
  status     String   @default("pending") @db.VarChar(20) // pending, accepted, expired, revoked
  invitedAt  DateTime @default(now()) @map("invited_at")
  acceptedAt DateTime? @map("accepted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  owner User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, email])
  @@index([ownerId])
  @@map("team_members")
}

/// Property listing owned by a landlord
model Property {
  id          String         @id @default(uuid()) @db.Uuid
  landlordId  String         @map("landlord_id") @db.Uuid
  title       String         @db.VarChar(100)
  description String         @db.Text
  type        PropertyType   @default(APARTMENT)
  status      PropertyStatus @default(DRAFT)

  // Location
  city         String @db.VarChar(50)
  neighborhood String @db.VarChar(100)
  address      String @db.VarChar(200)
  latitude     Float?
  longitude    Float?

  // Pricing (COP integers)
  monthlyRent Int @map("monthly_rent")
  adminFee    Int @default(0) @map("admin_fee")
  deposit     Int @default(0)

  // Characteristics
  bedrooms      Int  @default(1)
  bathrooms     Int  @default(1)
  area          Int // square meters
  floor         Int?
  parkingSpaces Int? @map("parking_spaces")
  stratum       Int? // Colombian stratum 1-6
  yearBuilt     Int? @map("year_built")

  // Amenities stored as array of string IDs
  amenities String[] @default([])

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  landlord       User            @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  images         PropertyImage[]
  applications   Application[]
  contracts      Contract[]
  leases         Lease[]
  availabilities PropertyAvailability[]
  visits         PropertyVisit[]
  propertyAccess PropertyAccess[]
  wishlistItems  WishlistItem[]

  @@index([landlordId])
  @@index([city])
  @@index([status])
  @@index([monthlyRent])
  @@index([bedrooms])
  @@index([type])
  @@map("properties")
}

/// Image for a property, ordered 0-9 with first as thumbnail
model PropertyImage {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  url        String   @db.VarChar(500)
  order      Int      @default(0) // 0-9, first is thumbnail
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, order])
  @@index([propertyId])
  @@map("property_images")
}

/// Property access granted to agents by landlords
/// Allows agents to manage properties on behalf of landlords
model PropertyAccess {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  grantedById String   @map("granted_by_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent      User     @relation("AgentAccess", fields: [agentId], references: [id])
  grantedBy  User     @relation("GrantedAccess", fields: [grantedById], references: [id])

  @@unique([propertyId, agentId])
  @@index([agentId])
  @@index([propertyId])
  @@map("property_access")
}

/// Rental application from tenant to property
model Application {
  id          String            @id @default(uuid()) @db.Uuid
  propertyId  String            @map("property_id") @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  status      ApplicationStatus @default(DRAFT)
  currentStep Int               @default(1) @map("current_step")

  // Wizard steps as separate JSON fields (validated in application layer)
  personalInfo   Json? @map("personal_info") // Step 1
  employmentInfo Json? @map("employment_info") // Step 2
  incomeInfo     Json? @map("income_info") // Step 3
  referencesInfo Json? @map("references_info") // Step 4
  // Step 5: Documents (separate table)
  // Step 6: Review (no data, just submit)

  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  property        Property                    @relation(fields: [propertyId], references: [id])
  tenant          User                        @relation("TenantApplications", fields: [tenantId], references: [id])
  documents       ApplicationDocument[]
  events          ApplicationEvent[]
  riskScore       RiskScoreResult?
  notes           LandlordNote[]
  contract        Contract?
  conversation    ApplicationConversation?
  featureSnapshot ApplicationFeatureSnapshot?
  predictionLog   PredictionLog?

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@map("applications")
}

/// Document uploaded as part of an application
model ApplicationDocument {
  id            String       @id @default(uuid()) @db.Uuid
  applicationId String       @map("application_id") @db.Uuid
  type          DocumentType
  storagePath   String       @map("storage_path") @db.VarChar(500)
  originalName  String       @map("original_name") @db.VarChar(255)
  mimeType      String       @map("mime_type") @db.VarChar(100)
  size          Int // bytes
  createdAt     DateTime     @default(now()) @map("created_at")

  // Relations
  application    Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  analysisResult DocumentAnalysisResult?

  @@index([applicationId])
  @@index([type])
  @@map("application_documents")
}

/// Event log entry for application audit trail
model ApplicationEvent {
  id            String               @id @default(uuid()) @db.Uuid
  applicationId String               @map("application_id") @db.Uuid
  type          ApplicationEventType
  actorId       String               @map("actor_id") @db.Uuid
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now()) @map("created_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actor       User        @relation("UserEvents", fields: [actorId], references: [id])

  @@index([applicationId])
  @@index([actorId])
  @@index([createdAt])
  @@map("application_events")
}

/// Chat conversation for a rental application
/// Auto-created when application is submitted, deleted on reject/withdraw
model ApplicationConversation {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @unique @map("application_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@map("application_conversations")
}

/// Individual chat message in an application conversation
model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String   @db.Text
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   ApplicationConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User @relation("ChatMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

/// Risk score result for an application
/// Stores the computed score and all component scores
model RiskScoreResult {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @unique @map("application_id") @db.Uuid
  totalScore    Int       @map("total_score")
  level         RiskLevel

  // Component scores (0-100 each, except paymentHistory which is 0-15 bonus)
  financialScore      Int @map("financial_score")
  stabilityScore      Int @map("stability_score")
  historyScore        Int @map("history_score")
  integrityScore      Int @map("integrity_score")
  paymentHistoryScore Int @default(0) @map("payment_history_score")

  // JSON arrays for explainability
  signals    Json @default("[]") // Raw signals detected
  drivers    Json @default("[]") // Main factors affecting score
  flags      Json @default("[]") // Warning flags
  conditions Json @default("[]") // Suggested rental conditions

  // AI explanation (for PRO+ tier in Phase 10)
  explanation String? @db.Text

  // Versioning
  algorithmVersion String   @default("1.0") @map("algorithm_version")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([level])
  @@map("risk_score_results")
}

/// Private note from landlord about a candidate
/// Only visible to the landlord, not the tenant
model LandlordNote {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  landlordId    String   @map("landlord_id") @db.Uuid
  content       String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  landlord    User        @relation("LandlordNotes", fields: [landlordId], references: [id])

  // One note per landlord per application
  @@unique([applicationId, landlordId])
  @@index([applicationId])
  @@index([landlordId])
  @@map("landlord_notes")
}

/// Rental contract between landlord and tenant
/// Created from an APPROVED application
model Contract {
  id            String         @id @default(uuid()) @db.Uuid
  applicationId String         @unique @map("application_id") @db.Uuid
  propertyId    String         @map("property_id") @db.Uuid
  landlordId    String         @map("landlord_id") @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  status        ContractStatus @default(DRAFT)

  // Contract terms
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  monthlyRent Int      @map("monthly_rent")
  deposit     Int
  paymentDay  Int      @map("payment_day") // 1-28

  // Insurance
  insuranceTier    InsuranceTier @default(NONE) @map("insurance_tier")
  insurancePremium Int           @default(0) @map("insurance_premium")  // Monthly premium in COP
  insuranceDetails String?       @map("insurance_details") @db.Text     // Coverage description text

  // Custom clauses as JSON array: [{ title: string, content: string }]
  customClauses Json @default("[]") @map("custom_clauses")

  // Document storage
  contractHtml  String? @map("contract_html") @db.Text // HTML for preview/signature
  signedPdfPath String? @map("signed_pdf_path") // Supabase Storage path
  documentHash  String? @map("document_hash") // SHA-256 of contractHtml at signing

  // Signature audit trails (JSON with full Ley 527 compliance data)
  landlordSignature Json? @map("landlord_signature")
  tenantSignature   Json? @map("tenant_signature")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  signedAt    DateTime? @map("signed_at") // When both parties signed
  activatedAt DateTime? @map("activated_at") // When start_date arrived

  // Relations
  application Application @relation(fields: [applicationId], references: [id])
  property    Property    @relation(fields: [propertyId], references: [id])
  landlord    User        @relation("LandlordContracts", fields: [landlordId], references: [id])
  tenant      User        @relation("TenantContracts", fields: [tenantId], references: [id])
  lease       Lease?

  @@index([landlordId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@map("contracts")
}

/// Active lease tracking the rental relationship
/// Created automatically when Contract becomes ACTIVE
model Lease {
  id         String      @id @default(uuid()) @db.Uuid
  contractId String      @unique @map("contract_id") @db.Uuid
  propertyId String      @map("property_id") @db.Uuid
  landlordId String      @map("landlord_id") @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  status     LeaseStatus @default(ACTIVE)

  // Denormalized data (snapshot at lease creation)
  propertyAddress String  @map("property_address") @db.VarChar(300)
  propertyCity    String  @map("property_city") @db.VarChar(50)
  landlordName    String  @map("landlord_name") @db.VarChar(100)
  landlordEmail   String  @map("landlord_email") @db.VarChar(255)
  tenantName      String  @map("tenant_name") @db.VarChar(100)
  tenantEmail     String  @map("tenant_email") @db.VarChar(255)
  tenantPhone     String? @map("tenant_phone") @db.VarChar(20)

  // Contract terms (immutable copy)
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  monthlyRent Int      @map("monthly_rent")
  deposit     Int
  paymentDay  Int      @map("payment_day") // 1-28

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  contract        Contract               @relation(fields: [contractId], references: [id])
  property        Property               @relation(fields: [propertyId], references: [id])
  landlord        User                   @relation("LandlordLeases", fields: [landlordId], references: [id])
  tenant          User                   @relation("TenantLeases", fields: [tenantId], references: [id])
  payments        Payment[]
  paymentRequests TenantPaymentRequest[]
  leaseDocuments  LeaseDocument[]

  @@index([landlordId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@map("leases")
}

/// Document attached to a lease (inventory, addendum, photo, etc.)
model LeaseDocument {
  id         String            @id @default(cuid())
  leaseId    String            @map("lease_id") @db.Uuid
  uploadedBy String            @map("uploaded_by") @db.Uuid
  type       LeaseDocumentType
  fileName   String            @map("file_name") @db.VarChar(255)
  filePath   String            @map("file_path") @db.VarChar(500)
  fileSize   Int               @map("file_size")
  mimeType   String            @map("mime_type") @db.VarChar(100)
  createdAt  DateTime          @default(now()) @map("created_at")

  // Relations
  lease    Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  uploader User  @relation("UploadedLeaseDocuments", fields: [uploadedBy], references: [id])

  @@index([leaseId])
  @@index([uploadedBy])
  @@map("lease_documents")
}

/// Payment record for lease rent
/// Recorded manually by landlord when payment received
model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  leaseId         String        @map("lease_id") @db.Uuid
  amount          Int // COP amount
  method          PaymentMethod
  referenceNumber String        @map("reference_number") @db.VarChar(100)

  // Payment timing
  paymentDate DateTime @map("payment_date") @db.Date
  periodMonth Int      @map("period_month") // 1-12
  periodYear  Int      @map("period_year") // e.g., 2026

  // Optional notes
  notes String? @db.VarChar(500)

  // Audit
  recordedBy String   @map("recorded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  lease          Lease                 @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  recorder       User                  @relation("RecordedPayments", fields: [recordedBy], references: [id])
  paymentRequest TenantPaymentRequest?

  // Prevent duplicate payment records for same month
  @@unique([leaseId, periodMonth, periodYear])
  @@index([leaseId])
  @@index([paymentDate])
  @@map("payments")
}

/// Landlord's configured payment methods for tenants to use
/// Landlords set up their bank accounts for tenants to transfer rent payments
model LandlordPaymentMethod {
  id         String @id @default(uuid()) @db.Uuid
  landlordId String @map("landlord_id") @db.Uuid

  // Bank account details
  bankName             String      @map("bank_name") @db.VarChar(100)
  accountType          AccountType @map("account_type")
  accountNumber        String      @map("account_number") @db.VarChar(50)
  holderName           String      @map("holder_name") @db.VarChar(200)
  holderDocumentNumber String?     @map("holder_document_number") @db.VarChar(20)

  // For Nequi/Daviplata
  phoneNumber String? @map("phone_number") @db.VarChar(20)

  // Payment method type
  methodType PaymentMethod @map("method_type")

  // Instructions from landlord
  instructions String? @db.VarChar(500)

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  landlord User @relation("LandlordPaymentMethods", fields: [landlordId], references: [id])

  @@index([landlordId])
  @@index([methodType])
  @@map("landlord_payment_methods")
}

/// Tenant-initiated payment request (pending landlord validation)
/// Tenants submit payment requests with receipts, landlord approves/rejects
model TenantPaymentRequest {
  id       String @id @default(uuid()) @db.Uuid
  leaseId  String @map("lease_id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Payment details
  amount        Int // COP amount
  paymentMethod PaymentMethod @map("payment_method")
  periodMonth   Int           @map("period_month") // 1-12
  periodYear    Int           @map("period_year")
  paymentDate   DateTime      @map("payment_date") @db.Date

  // For bank transfer: receipt path in Supabase Storage
  receiptPath String? @map("receipt_path") @db.VarChar(500)

  // For PSE: mock transaction reference
  pseTransactionId String? @map("pse_transaction_id") @db.VarChar(100)
  pseBankCode      String? @map("pse_bank_code") @db.VarChar(20)

  // Reference number (from receipt or PSE)
  referenceNumber String? @map("reference_number") @db.VarChar(100)

  // Status
  status TenantPaymentRequestStatus @default(PENDING_VALIDATION)

  // Validation
  validatedAt     DateTime? @map("validated_at")
  validatedBy     String?   @map("validated_by") @db.Uuid
  rejectionReason String?   @map("rejection_reason") @db.VarChar(500)

  // Link to created Payment (if approved)
  paymentId String? @unique @map("payment_id") @db.Uuid

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  lease     Lease           @relation(fields: [leaseId], references: [id])
  tenant    User            @relation("TenantPaymentRequests", fields: [tenantId], references: [id])
  validator User?           @relation("PaymentValidations", fields: [validatedBy], references: [id])
  payment   Payment?        @relation(fields: [paymentId], references: [id])
  dispute   PaymentDispute?

  @@index([leaseId])
  @@index([tenantId])
  @@index([status])
  @@map("tenant_payment_requests")
}

/// Dispute for rejected payment request
/// Tenant can open dispute when landlord rejects their payment
model PaymentDispute {
  id               String @id @default(uuid()) @db.Uuid
  paymentRequestId String @unique @map("payment_request_id") @db.Uuid

  // Dispute details
  reason                 String  @db.Text
  additionalEvidencePath String? @map("additional_evidence_path") @db.VarChar(500)

  // Status
  status PaymentDisputeStatus @default(OPEN)

  // Resolution
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by") @db.Uuid
  resolution String?   @db.Text

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  paymentRequest TenantPaymentRequest @relation(fields: [paymentRequestId], references: [id])
  resolver       User?                @relation("DisputeResolutions", fields: [resolvedBy], references: [id])

  @@index([status])
  @@map("payment_disputes")
}

/// Landlord's availability configuration for property visits
/// Stores recurring weekly schedule (one row per time window per day)
model PropertyAvailability {
  id           String   @id @default(uuid()) @db.Uuid
  propertyId   String   @map("property_id") @db.Uuid
  dayOfWeek    Int      @map("day_of_week")       // 0=Sunday, 6=Saturday
  startTime    String   @map("start_time")        // "09:00" (HH:mm 24h)
  endTime      String   @map("end_time")          // "17:00"
  slotDuration Int      @map("slot_duration")     // Minutes: 15, 30, 45, 60
  isActive     Boolean  @default(true) @map("is_active")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, dayOfWeek, startTime])  // Prevent overlapping windows
  @@index([propertyId])
  @@map("property_availabilities")
}

/// Individual property visit request
model PropertyVisit {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @map("property_id") @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  status            VisitStatus @default(PENDING)

  // Visit timing
  visitDate         DateTime    @map("visit_date") @db.Date
  startTime         String      @map("start_time")      // "10:00"
  endTime           String      @map("end_time")        // "10:30"

  // Optional notes
  tenantNotes       String?     @map("tenant_notes") @db.VarChar(500)
  landlordNotes     String?     @map("landlord_notes") @db.VarChar(500)
  rejectionReason   String?     @map("rejection_reason") @db.VarChar(500)
  cancellationReason String?    @map("cancellation_reason") @db.VarChar(500)
  cancelledBy       String?     @map("cancelled_by") @db.Uuid  // Who cancelled

  // Rescheduling chain
  rescheduledFromId String?     @unique @map("rescheduled_from_id") @db.Uuid
  rescheduledToId   String?     @unique @map("rescheduled_to_id") @db.Uuid

  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  property          Property    @relation(fields: [propertyId], references: [id])
  tenant            User        @relation("TenantVisits", fields: [tenantId], references: [id])
  rescheduledFrom   PropertyVisit? @relation("VisitReschedule", fields: [rescheduledFromId], references: [id])
  rescheduledTo     PropertyVisit? @relation("VisitReschedule")

  @@index([propertyId])
  @@index([tenantId])
  @@index([visitDate])
  @@index([status])
  @@map("property_visits")
}

/// Template for notifications (admin-managed)
/// Each template has both email and push variants
model NotificationTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)  // e.g., "APPLICATION_RECEIVED"
  name        String   @db.VarChar(100)          // Human-readable name
  description String?  @db.Text                  // Admin notes

  // Email template (Markdown converted to HTML at send time)
  emailSubject  String  @map("email_subject") @db.VarChar(200)
  emailBody     String  @map("email_body") @db.Text  // Markdown content

  // Push notification template
  pushTitle     String  @map("push_title") @db.VarChar(100)
  pushBody      String  @map("push_body") @db.VarChar(500)

  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

/// Log of sent notifications for auditing and debugging
model NotificationLog {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  templateCode String              @map("template_code") @db.VarChar(50)
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)

  // Delivery details
  recipient    String              @db.VarChar(255)  // Email address or FCM token
  subject      String?             @db.VarChar(200)  // For email
  errorMessage String?             @map("error_message") @db.Text

  // Timing
  sentAt       DateTime?           @map("sent_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  // Relations
  user         User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([templateCode])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

/// Configurable subscription plan definition
/// Admin can modify prices. Different plans for TENANT vs LANDLORD.
model SubscriptionPlanConfig {
  id          String        @id @default(uuid()) @db.Uuid
  planType    PlanType      @map("plan_type")        // TENANT or LANDLORD
  tier        SubscriptionPlan                        // FREE, PRO, BUSINESS
  name        String        @db.VarChar(100)          // Display name: "Tenant Pro", "Landlord Business"
  description String?       @db.Text

  // Pricing (COP - 0 for free plan)
  monthlyPrice Int          @default(0) @map("monthly_price")
  annualPrice  Int          @default(0) @map("annual_price")   // Full year price (discounted)

  // Limits
  maxProperties     Int     @default(1) @map("max_properties")      // -1 = unlimited
  maxScoringViews   Int     @default(1) @map("max_scoring_views")   // Per month, -1 = unlimited
  hasPremiumScoring Boolean @default(false) @map("has_premium_scoring")
  hasApiAccess      Boolean @default(false) @map("has_api_access")

  // Micropayment price (for tenant free extra scoring views)
  scoringViewPrice  Int     @default(0) @map("scoring_view_price")  // COP per extra view

  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]

  @@unique([planType, tier])  // One config per role+tier combo
  @@index([planType])
  @@index([isActive])
  @@map("subscription_plan_configs")
}

/// User's active subscription
model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  planId    String             @map("plan_id") @db.Uuid
  status    SubscriptionStatus @default(TRIAL)
  cycle     BillingCycle       @default(MONTHLY)

  // Period
  startDate   DateTime         @map("start_date")
  endDate     DateTime         @map("end_date")
  trialEndsAt DateTime?        @map("trial_ends_at")  // Set only during trial

  // Cancellation
  cancelledAt   DateTime?      @map("cancelled_at")
  cancelReason  String?        @map("cancel_reason") @db.VarChar(500)

  // Auto-renew
  autoRenew   Boolean          @default(true) @map("auto_renew")

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  plan     SubscriptionPlanConfig @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

/// Payment record for a subscription (via PSE mock)
model SubscriptionPayment {
  id              String   @id @default(uuid()) @db.Uuid
  subscriptionId  String   @map("subscription_id") @db.Uuid
  amount          Int      // COP
  cycle           BillingCycle

  // PSE mock reference
  pseTransactionId String? @map("pse_transaction_id") @db.VarChar(100)
  status           String  @default("PENDING") @db.VarChar(20)  // PENDING, SUCCESS, FAILED

  // Period covered
  periodStart DateTime    @map("period_start")
  periodEnd   DateTime    @map("period_end")

  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@map("subscription_payments")
}

/// Track tenant scoring view usage per month
/// Enforces monthly limits for free tier tenants
model ScoringUsage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  month     Int      // 1-12
  year      Int      // e.g., 2026
  viewCount Int      @default(0) @map("view_count")  // Number of scoring views used

  // Micropayment tracking
  paidViewCount Int  @default(0) @map("paid_view_count")  // Extra views purchased via micropayment

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, month, year])
  @@index([userId])
  @@map("scoring_usage")
}

/// Tenant's saved/favorite properties
/// Stores wishlist items with compound unique for idempotent add
model WishlistItem {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("wishlist_items")
}

/// Tenant search preferences for cross-device sync and recommendations
/// 1:1 with User via @unique userId - use upsert for idempotent updates
model TenantPreference {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  preferredCities        String[]  @default([])
  preferredBedrooms      Int?      @map("preferred_bedrooms")
  preferredPropertyTypes String[]  @default([]) @map("preferred_property_types")
  minBudget              Int?      @map("min_budget")
  maxBudget              Int?      @map("max_budget")
  petFriendly            Boolean   @default(false) @map("pet_friendly")
  moveInDate             DateTime? @map("move_in_date") @db.Date
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_preferences")
}

/// Coupon code for subscription discounts
/// Admin-managed with validation rules and usage tracking
model Coupon {
  id              String     @id @default(uuid()) @db.Uuid
  code            String     @unique @db.VarChar(50)
  type            CouponType

  // Discount values (only one used based on type)
  percentageOff   Int?       @map("percentage_off")   // 1-100 for PERCENTAGE
  amountOff       Int?       @map("amount_off")       // COP for FIXED_AMOUNT
  freeMonths      Int?       @map("free_months")      // Months for FREE_MONTHS

  // Validity
  validFrom       DateTime   @map("valid_from")
  validUntil      DateTime   @map("valid_until")

  // Usage limits
  maxUses         Int?       @map("max_uses")          // null = unlimited
  currentUses     Int        @default(0) @map("current_uses")

  // Plan applicability (empty = all plans)
  applicablePlans String[]   @default([]) @map("applicable_plans")

  // Description for admin
  description     String?    @db.Text

  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  usages          CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([validUntil])
  @@map("coupons")
}

/// Tracks coupon usage per user to prevent duplicate redemptions
model CouponUsage {
  id             String   @id @default(uuid()) @db.Uuid
  couponId       String   @map("coupon_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  subscriptionId String?  @map("subscription_id") @db.Uuid
  usedAt         DateTime @default(now()) @map("used_at")

  // Relations
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
  @@index([userId])
  @@map("coupon_usages")
}

// ============================================
// INMOBILIARIA ENUMS (Phase 2.2)
// ============================================

/// Role within an agency team
enum AgencyMemberRole {
  ADMIN
  AGENTE
  CONTADOR
  VIEWER
}

/// Status of an agency team member
enum AgencyMemberStatus {
  ACTIVE
  INVITED
  INACTIVE
}

/// Agent internal role within agency hierarchy
enum AgentRole {
  AGENT
  COORDINATOR
  DIRECTOR
}

/// Agent availability status
enum AgentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

/// Agent specialization
enum AgentSpecialization {
  RESIDENTIAL
  COMMERCIAL
  BOTH
}

/// Status of a property consignment agreement
enum ConsignacionStatus {
  ACTIVE
  TERMINATED
  EXPIRED
  PENDING
}

/// Availability of a consigned property
enum ConsignacionAvailability {
  AVAILABLE
  RENTED
  IN_PROCESS
  MAINTENANCE
}

/// Extended property type for agency (includes commercial)
enum ConsignacionPropertyType {
  APARTMENT
  HOUSE
  STUDIO
  COMMERCIAL
  OFFICE
  WAREHOUSE
}

/// Stage in the rental pipeline/sales funnel
enum PipelineStage {
  LEAD
  VISIT_SCHEDULED
  VISIT_DONE
  APPLICATION
  EVALUATION
  APPROVED
  CONTRACT
  HANDOVER
  COMPLETED
  LOST
}

/// Status of a monthly rent collection
enum CobroStatus {
  COBRO_PENDING
  PAID
  PARTIAL
  LATE
  DEFAULTED
}

/// Status of an owner disbursement
enum DispersionStatus {
  DISP_PENDING
  PROCESSING
  DISP_COMPLETED
  FAILED
}

/// Type of maintenance request
enum MantenimientoType {
  PLUMBING
  ELECTRICAL
  APPLIANCE
  STRUCTURAL
  PAINTING
  LOCKS
  OTHER_MAINT
}

/// Priority of a maintenance request
enum MantenimientoPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

/// Status of a maintenance request
enum MantenimientoStatus {
  REPORTED
  QUOTED
  MAINT_APPROVED
  IN_PROGRESS
  MAINT_COMPLETED
  MAINT_CANCELLED
}

/// Who pays for maintenance
enum MantenimientoPaidBy {
  OWNER
  TENANT_PAYS
  SPLIT
  AGENCY_PAYS
}

/// Status of a lease renewal process
enum RenovacionStatus {
  RENOV_PENDING
  NOTIFIED
  NEGOTIATING
  RENOV_APPROVED
  RENOV_SIGNED
  RENOV_COMPLETED
  RENOV_TERMINATED
}

/// Type of acta (delivery or return)
enum ActaType {
  ENTREGA
  DEVOLUCION
}

/// Status of an acta de entrega
enum ActaStatus {
  ACTA_DRAFT
  ACTA_IN_PROGRESS
  PENDING_SIGNATURES
  ACTA_COMPLETED
}

/// Condition assessment for acta items
enum ItemCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

/// Status of a property document in agency context
enum AgencyDocumentStatus {
  DOC_DRAFT
  PENDING_SIGNATURE
  DOC_SIGNED
  DOC_EXPIRED
}

/// Category of document templates
enum DocumentTemplateCategory {
  CONTRATO
  ACTA
  INVENTARIO
  POLIZA
  CARTA
  OTRO
}

/// Status of an external integration
enum IntegrationStatus {
  INT_ACTIVE
  INT_INACTIVE
  INT_PENDING
  INT_ERROR
}

/// Category of external integrations
enum IntegrationCategory {
  PAYMENTS
  ACCOUNTING
  COMMUNICATIONS
  STORAGE
}

/// Document type identifier (CC, NIT, etc.)
enum PropietarioDocumentType {
  CC
  CE
  NIT
  PASSPORT
}

// ============================================
// INMOBILIARIA MODELS (Phase 2.2)
// ============================================

/// Real estate agency organization
/// Groups users (agents, admins, accountants) under one entity
model Agency {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(200)
  nit         String? @unique @db.VarChar(20)
  address     String? @db.VarChar(300)
  city        String? @db.VarChar(50)
  phone       String? @db.VarChar(20)
  email       String? @db.VarChar(255)
  logoUrl     String? @map("logo_url") @db.VarChar(500)

  // Financial defaults
  defaultCommissionPercent Float   @default(10) @map("default_commission_percent")
  defaultLateFeePercent    Float   @default(2) @map("default_late_fee_percent")
  paymentDueDay            Int     @default(5) @map("payment_due_day")     // Day of month
  disbursementDay          Int     @default(15) @map("disbursement_day")   // Day of month

  // Reminder config (JSON arrays of days)
  reminderDaysBefore Json @default("[3, 1]") @map("reminder_days_before")
  reminderDaysAfter  Json @default("[1, 3, 7, 15]") @map("reminder_days_after")

  // Business profile (from onboarding)
  portfolioSize    String? @map("portfolio_size") @db.VarChar(20)
  yearsInBusiness  Int?    @map("years_in_business")
  services         Json    @default("[]")
  website          String? @db.Text

  // Branding
  branding Json @default("{}")

  // Legal info
  legalRepresentative String? @map("legal_representative") @db.VarChar(200)
  legalDocumentNumber String? @map("legal_document_number") @db.VarChar(20)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  members            AgencyMember[]
  propietarios       Propietario[]
  consignaciones     Consignacion[]
  pipelineItems      PipelineItem[]
  cobros             Cobro[]
  dispersiones       Dispersion[]
  mantenimientos     SolicitudMantenimiento[]
  renovaciones       Renovacion[]
  actas              ActaEntrega[]
  documentTemplates  AgencyDocumentTemplate[]
  documents          AgencyDocument[]
  integrations       AgencyIntegration[]

  @@map("agencies")
}

/// Membership of a user in an agency with role
model AgencyMember {
  id       String             @id @default(uuid()) @db.Uuid
  agencyId String             @map("agency_id") @db.Uuid
  userId   String             @map("user_id") @db.Uuid
  role     AgencyMemberRole   @default(AGENTE)
  status   AgencyMemberStatus @default(ACTIVE)

  // Agent-specific fields (only when role = AGENTE)
  agentRole       AgentRole?           @map("agent_role")
  agentStatus     AgentStatus?         @map("agent_status")
  specialization  AgentSpecialization? @map("specialization")
  commissionSplit Float?               @map("commission_split") // % of agency commission
  zone            String?              @db.VarChar(100)
  hireDate        DateTime?            @map("hire_date") @db.Date

  // Invitation fields (for token-based member invitations)
  invitationToken     String?   @unique @map("invitation_token")
  invitationExpiresAt DateTime? @map("invitation_expires_at")
  invitedEmail        String?   @map("invited_email") // For inviting users not yet registered

  // Granular permissions override. Null = use role defaults (AGENCY_ROLE_DEFAULTS).
  // Only written when admin customizes permissions for this member.
  permissions Json? /// Custom permissions override. Null = use role defaults

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId])
  @@index([userId])
  @@map("agency_members")
}

/// Property owner - client of the agency
/// Not necessarily a platform User; managed by agency
model Propietario {
  id               String                  @id @default(uuid()) @db.Uuid
  agencyId         String                  @map("agency_id") @db.Uuid
  name             String                  @db.VarChar(200)
  email            String?                 @db.VarChar(255)
  phone            String?                 @db.VarChar(20)
  documentType     PropietarioDocumentType @default(CC) @map("document_type")
  documentNumber   String                  @map("document_number") @db.VarChar(30)
  address          String?                 @db.VarChar(300)
  city             String?                 @db.VarChar(50)

  // Bank account for disbursements
  bankName             String?  @map("bank_name") @db.VarChar(100)
  bankAccountType      String?  @map("bank_account_type") @db.VarChar(20) // savings | checking
  bankAccountNumber    String?  @map("bank_account_number") @db.VarChar(50)
  bankAccountHolder    String?  @map("bank_account_holder") @db.VarChar(200)

  notes String? @db.Text
  tags  String[] @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency         Agency                   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignaciones Consignacion[]
  dispersiones   Dispersion[]
  mantenimientos SolicitudMantenimiento[]
  renovaciones   Renovacion[]
  actas          ActaEntrega[]

  @@unique([agencyId, documentNumber])
  @@index([agencyId])
  @@map("propietarios")
}

/// Property consignment agreement
/// Wraps an existing Property with agency-specific data
model Consignacion {
  id             String                    @id @default(uuid()) @db.Uuid
  agencyId       String                    @map("agency_id") @db.Uuid
  propertyId     String?                   @map("property_id") @db.Uuid
  propietarioId  String                    @map("propietario_id") @db.Uuid
  agenteUserId   String?                   @map("agente_user_id") @db.Uuid // User.id of assigned agent

  // Property info (denormalized for agency dashboard)
  propertyTitle   String  @map("property_title") @db.VarChar(200)
  propertyAddress String  @map("property_address") @db.VarChar(300)
  propertyCity    String  @map("property_city") @db.VarChar(50)
  propertyZone    String? @map("property_zone") @db.VarChar(100)
  propertyType    ConsignacionPropertyType @default(APARTMENT) @map("property_type")
  propertyThumbnail String? @map("property_thumbnail") @db.VarChar(500)
  monthlyRent     Int     @map("monthly_rent")
  adminFee        Int     @default(0) @map("admin_fee")

  // Consignment terms
  commissionPercent Float    @map("commission_percent")
  contractDate      DateTime @map("contract_date") @db.Date
  contractEndDate   DateTime? @map("contract_end_date") @db.Date
  minimumTerm       Int?     @map("minimum_term") // months

  // Status
  status       ConsignacionStatus       @default(ACTIVE)
  availability ConsignacionAvailability @default(AVAILABLE)

  // Current lease tracking (denormalized)
  currentLeaseId   String? @map("current_lease_id") @db.Uuid
  currentTenantName String? @map("current_tenant_name") @db.VarChar(200)
  leaseEndDate     DateTime? @map("lease_end_date") @db.Date

  // Documents
  consignmentContractUrl String? @map("consignment_contract_url") @db.VarChar(500)
  photosUrls             String[] @default([]) @map("photos_urls")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency         Agency                   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  propietario    Propietario              @relation(fields: [propietarioId], references: [id])
  pipelineItems  PipelineItem[]
  cobros         Cobro[]
  mantenimientos SolicitudMantenimiento[]
  renovaciones   Renovacion[]
  actas          ActaEntrega[]
  documents      AgencyDocument[]

  @@index([agencyId])
  @@index([propietarioId])
  @@index([agenteUserId])
  @@index([status])
  @@index([availability])
  @@map("consignaciones")
}

/// Pipeline item tracking a prospect through the rental funnel
model PipelineItem {
  id              String  @id @default(uuid()) @db.Uuid
  agencyId        String  @map("agency_id") @db.Uuid
  consignacionId  String  @map("consignacion_id") @db.Uuid
  agenteUserId    String? @map("agente_user_id") @db.Uuid

  // Candidate info (denormalized)
  candidateName   String  @map("candidate_name") @db.VarChar(200)
  candidateEmail  String? @map("candidate_email") @db.VarChar(255)
  candidatePhone  String? @map("candidate_phone") @db.VarChar(20)
  candidateAvatar String? @map("candidate_avatar") @db.VarChar(500)
  riskScore       Int?    @map("risk_score")
  riskLevel       String? @map("risk_level") @db.VarChar(5)

  // Pipeline stage
  stage           PipelineStage @default(LEAD)
  enteredStageAt  DateTime      @default(now()) @map("entered_stage_at")
  daysInStage     Int           @default(0) @map("days_in_stage")

  // Activity
  nextAction      String?   @map("next_action") @db.VarChar(500)
  nextActionDate  DateTime? @map("next_action_date") @db.Date
  lastContactDate DateTime? @map("last_contact_date") @db.Date
  notes           String?   @db.Text

  // Outcome
  lostReason       String? @map("lost_reason") @db.VarChar(500)
  completedLeaseId String? @map("completed_lease_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency       Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignacion Consignacion @relation(fields: [consignacionId], references: [id])

  @@index([agencyId])
  @@index([consignacionId])
  @@index([agenteUserId])
  @@index([stage])
  @@map("pipeline_items")
}

/// Monthly rent collection record
model Cobro {
  id              String @id @default(uuid()) @db.Uuid
  agencyId        String @map("agency_id") @db.Uuid
  consignacionId  String @map("consignacion_id") @db.Uuid
  leaseId         String? @map("lease_id") @db.Uuid
  propietarioId   String @map("propietario_id") @db.Uuid
  agenteUserId    String? @map("agente_user_id") @db.Uuid

  // Tenant info (denormalized)
  tenantName  String? @map("tenant_name") @db.VarChar(200)
  tenantEmail String? @map("tenant_email") @db.VarChar(255)
  tenantPhone String? @map("tenant_phone") @db.VarChar(20)

  // Property info (denormalized)
  propertyTitle String @map("property_title") @db.VarChar(200)

  // Amounts (COP)
  month          String @db.VarChar(7) // '2026-02'
  rentAmount     Int    @map("rent_amount")
  adminAmount    Int    @default(0) @map("admin_amount")
  totalAmount    Int    @map("total_amount")
  lateFee        Int    @default(0) @map("late_fee")
  totalWithFees  Int    @map("total_with_fees")

  // Payment tracking
  status           CobroStatus @default(COBRO_PENDING)
  dueDate          DateTime    @map("due_date") @db.Date
  paidDate         DateTime?   @map("paid_date") @db.Date
  paidAmount       Int         @default(0) @map("paid_amount")
  pendingAmount    Int         @map("pending_amount")
  paymentMethod    String?     @map("payment_method") @db.VarChar(50)
  paymentReference String?     @map("payment_reference") @db.VarChar(100)

  // Reminders
  daysLate         Int @default(0) @map("days_late")
  remindersSent    Int @default(0) @map("reminders_sent")
  lastReminderDate DateTime? @map("last_reminder_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignacion  Consignacion   @relation(fields: [consignacionId], references: [id])
  dispersionItems DispersionItem[]

  @@unique([consignacionId, month])
  @@index([agencyId])
  @@index([consignacionId])
  @@index([propietarioId])
  @@index([month])
  @@index([status])
  @@map("cobros")
}

/// Owner disbursement - aggregates cobros for a month per propietario
model Dispersion {
  id              String @id @default(uuid()) @db.Uuid
  agencyId        String @map("agency_id") @db.Uuid
  propietarioId   String @map("propietario_id") @db.Uuid

  // Propietario info (denormalized)
  propietarioName        String @map("propietario_name") @db.VarChar(200)
  propietarioBankName    String? @map("propietario_bank_name") @db.VarChar(100)
  propietarioBankAccount String? @map("propietario_bank_account") @db.VarChar(50)

  month              String @db.VarChar(7) // '2026-02'
  totalCollected     Int    @map("total_collected")
  totalCommission    Int    @map("total_commission")
  netToPropietario   Int    @map("net_to_propietario")

  // Status
  status             DispersionStatus @default(DISP_PENDING)
  approvedBy         String?          @map("approved_by") @db.Uuid
  approvedAt         DateTime?        @map("approved_at")
  processedAt        DateTime?        @map("processed_at")
  transferReference  String?          @map("transfer_reference") @db.VarChar(100)
  failureReason      String?          @map("failure_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency      Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  propietario Propietario      @relation(fields: [propietarioId], references: [id])
  items       DispersionItem[]

  @@unique([propietarioId, month])
  @@index([agencyId])
  @@index([propietarioId])
  @@index([month])
  @@index([status])
  @@map("dispersiones")
}

/// Individual item in a dispersion (one per cobro)
model DispersionItem {
  id              String @id @default(uuid()) @db.Uuid
  dispersionId    String @map("dispersion_id") @db.Uuid
  cobroId         String @map("cobro_id") @db.Uuid
  propertyTitle   String @map("property_title") @db.VarChar(200)
  rentCollected   Int    @map("rent_collected")
  commissionPercent Float @map("commission_percent")
  commissionAmount Int   @map("commission_amount")
  netAmount       Int    @map("net_amount")

  // Relations
  dispersion Dispersion @relation(fields: [dispersionId], references: [id], onDelete: Cascade)
  cobro      Cobro      @relation(fields: [cobroId], references: [id])

  @@index([dispersionId])
  @@index([cobroId])
  @@map("dispersion_items")
}

/// Maintenance request for a consigned property
model SolicitudMantenimiento {
  id              String  @id @default(uuid()) @db.Uuid
  agencyId        String  @map("agency_id") @db.Uuid
  consignacionId  String  @map("consignacion_id") @db.Uuid
  propietarioId   String  @map("propietario_id") @db.Uuid
  agenteUserId    String? @map("agente_user_id") @db.Uuid

  // Denormalized info
  propertyTitle    String @map("property_title") @db.VarChar(200)
  tenantName       String? @map("tenant_name") @db.VarChar(200)
  propietarioName  String @map("propietario_name") @db.VarChar(200)

  // Request details
  type        MantenimientoType
  priority    MantenimientoPriority @default(MEDIUM)
  title       String                @db.VarChar(200)
  description String                @db.Text
  photoUrls   String[]              @default([]) @map("photo_urls")

  // Process
  status          MantenimientoStatus @default(REPORTED)
  selectedQuoteId String?             @map("selected_quote_id") @db.Uuid
  approvedAmount  Int?                @map("approved_amount")
  paidBy          MantenimientoPaidBy @default(OWNER)

  // Completion
  completedAt       DateTime? @map("completed_at")
  completionNotes   String?   @map("completion_notes") @db.Text
  completionPhotoUrls String[] @default([]) @map("completion_photo_urls")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency       Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignacion Consignacion        @relation(fields: [consignacionId], references: [id])
  propietario  Propietario         @relation(fields: [propietarioId], references: [id])
  quotes       MantenimientoQuote[]

  @@index([agencyId])
  @@index([consignacionId])
  @@index([status])
  @@index([priority])
  @@map("solicitudes_mantenimiento")
}

/// Vendor quote for a maintenance request
model MantenimientoQuote {
  id                String @id @default(uuid()) @db.Uuid
  solicitudId       String @map("solicitud_id") @db.Uuid
  providerName      String @map("provider_name") @db.VarChar(200)
  providerPhone     String? @map("provider_phone") @db.VarChar(20)
  amount            Int
  description       String @db.Text
  estimatedDays     Int    @map("estimated_days")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  solicitud SolicitudMantenimiento @relation(fields: [solicitudId], references: [id], onDelete: Cascade)

  @@index([solicitudId])
  @@map("mantenimiento_quotes")
}

/// Lease renewal tracking
model Renovacion {
  id              String  @id @default(uuid()) @db.Uuid
  agencyId        String  @map("agency_id") @db.Uuid
  consignacionId  String  @map("consignacion_id") @db.Uuid
  leaseId         String? @map("lease_id") @db.Uuid
  propietarioId   String  @map("propietario_id") @db.Uuid
  agenteUserId    String? @map("agente_user_id") @db.Uuid

  // Denormalized info
  propertyTitle    String @map("property_title") @db.VarChar(200)
  propertyAddress  String @map("property_address") @db.VarChar(300)
  tenantName       String? @map("tenant_name") @db.VarChar(200)
  propietarioName  String @map("propietario_name") @db.VarChar(200)

  // Lease terms
  currentRent      Int      @map("current_rent")
  leaseStartDate   DateTime @map("lease_start_date") @db.Date
  leaseEndDate     DateTime @map("lease_end_date") @db.Date
  daysUntilExpiry  Int      @map("days_until_expiry")

  // IPC calculation
  ipcRate          Float?   @map("ipc_rate")
  proposedRent     Int?     @map("proposed_rent")
  negotiatedRent   Int?     @map("negotiated_rent")

  // Workflow
  status           RenovacionStatus @default(RENOV_PENDING)
  notifiedAt       DateTime?        @map("notified_at")
  approvedAt       DateTime?        @map("approved_at")
  signedAt         DateTime?        @map("signed_at")
  completedAt      DateTime?        @map("completed_at")

  // New lease reference
  newLeaseId       String?   @map("new_lease_id") @db.Uuid
  newLeaseStartDate DateTime? @map("new_lease_start_date") @db.Date
  newLeaseEndDate  DateTime? @map("new_lease_end_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency       Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignacion Consignacion        @relation(fields: [consignacionId], references: [id])
  propietario  Propietario         @relation(fields: [propietarioId], references: [id])
  history      RenovacionHistory[]

  @@index([agencyId])
  @@index([consignacionId])
  @@index([status])
  @@index([leaseEndDate])
  @@map("renovaciones")
}

/// Audit trail entry for renewal process
model RenovacionHistory {
  id            String @id @default(uuid()) @db.Uuid
  renovacionId  String @map("renovacion_id") @db.Uuid
  action        String @db.VarChar(100)
  description   String @db.Text
  actorName     String? @map("actor_name") @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  renovacion Renovacion @relation(fields: [renovacionId], references: [id], onDelete: Cascade)

  @@index([renovacionId])
  @@map("renovacion_history")
}

/// Property delivery or return act
model ActaEntrega {
  id              String   @id @default(uuid()) @db.Uuid
  agencyId        String   @map("agency_id") @db.Uuid
  type            ActaType
  consignacionId  String?  @map("consignacion_id") @db.Uuid
  leaseId         String?  @map("lease_id") @db.Uuid
  propietarioId   String   @map("propietario_id") @db.Uuid
  agenteUserId    String?  @map("agente_user_id") @db.Uuid

  // Denormalized
  propertyTitle   String  @map("property_title") @db.VarChar(200)
  propertyAddress String  @map("property_address") @db.VarChar(300)
  tenantName      String? @map("tenant_name") @db.VarChar(200)
  propietarioName String  @map("propietario_name") @db.VarChar(200)

  // Inventory (JSON arrays for flexibility)
  rooms    Json @default("[]") // RoomType[]
  items    Json @default("[]") // ActaInventoryItem[]

  // Meter readings (JSON)
  meterReadings Json @default("[]") @map("meter_readings")

  // Keys
  keysDelivered Json @default("[]") @map("keys_delivered")

  // General condition
  generalCondition     ItemCondition @default(GOOD) @map("general_condition")
  generalObservations  String?       @map("general_observations") @db.Text

  // For return acts - deposit handling
  depositAmount    Int? @map("deposit_amount")
  deductions       Json @default("[]") // ActaDeduction[]
  depositToReturn  Int? @map("deposit_to_return")

  // Photo documentation
  photoUrls String[] @default([]) @map("photo_urls")

  // Workflow
  status     ActaStatus @default(ACTA_DRAFT)
  signatures Json       @default("[]") // ActaSignature[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  consignacion Consignacion? @relation(fields: [consignacionId], references: [id])
  propietario  Propietario   @relation(fields: [propietarioId], references: [id])

  @@index([agencyId])
  @@index([consignacionId])
  @@index([status])
  @@map("actas_entrega")
}

/// Document template for agency document generation
model AgencyDocumentTemplate {
  id          String                   @id @default(uuid()) @db.Uuid
  agencyId    String                   @map("agency_id") @db.Uuid
  name        String                   @db.VarChar(200)
  category    DocumentTemplateCategory
  version     String                   @default("1.0") @db.VarChar(20)
  content     String                   @db.Text // Handlebars template
  variables   String[]                 @default([])
  isActive    Boolean                  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency    Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  documents AgencyDocument[]

  @@index([agencyId])
  @@index([category])
  @@map("agency_document_templates")
}

/// Generated document from a template
model AgencyDocument {
  id              String              @id @default(uuid()) @db.Uuid
  agencyId        String              @map("agency_id") @db.Uuid
  templateId      String?             @map("template_id") @db.Uuid
  consignacionId  String?             @map("consignacion_id") @db.Uuid

  name            String              @db.VarChar(200)
  content         String?             @db.Text // Rendered HTML
  filePath        String?             @map("file_path") @db.VarChar(500)
  status          AgencyDocumentStatus @default(DOC_DRAFT)

  // Signature tracking (JSON)
  signatures Json @default("[]")

